# Copy this file to .env and fill in your real values.
# Required by python-dotenv: no spaces around "=".

# Gemini (deployment_agent, log_analysis_agent, fix_suggestion_agent, patch_generation_agent)
GOOGLE_API_KEY=your_gemini_api_key_here

# Vercel (deployment_agent)
VERCEL_TOKEN=your_vercel_token_here
VERCEL_TEAM_ID=
VERCEL_PROJECT_NAME=your_vercel_project_name

# GitHub (patch_generation_agent, handle_approval merge step)
GITHUB_REPO=owner/repo
GITHUB_TOKEN=your_github_pat_here
BASE_BRANCH=main

# Ollama (issue_classification_agent, validation_agent)
# Defaults to http://localhost:11434 - only set if Ollama runs elsewhere
OLLAMA_API_BASE=http://localhost:11434
